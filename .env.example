# HubGH -- Variables de entorno
# Copiá este archivo a .env y editá los valores:
#   cp .env.example .env

# Contrasena root de MariaDB
MARIADB_ROOT_PASSWORD=frappe

# Nombre del sitio Frappe
FRAPPE_SITE_NAME=hubgh.local

# Contrasena del usuario Administrator de Frappe
ADMIN_PASSWORD=admin

# Dominio publico para despliegue con Caddy (HTTPS automatico)
PUBLIC_DOMAIN=intranet.comidasmarpel.com

# Correo para certificados Let's Encrypt
ACME_EMAIL=admin@comidasvarpel.com
